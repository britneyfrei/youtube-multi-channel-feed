# YouTube Data API v3 OAuth2 credentials
# Obtain these from the Google Cloud Console:
#   https://console.cloud.google.com/apis/credentials

YOUTUBE_CLIENT_ID=your_client_id_here
YOUTUBE_CLIENT_SECRET=your_client_secret_here

# Redirect URI registered in the Google Cloud Console for your OAuth2 client.
# For a CLI / installed-app flow use the out-of-band (OOB) value below.
YOUTUBE_REDIRECT_URI=urn:ietf:wg:oauth:2.0:oob

# After completing the OAuth2 consent flow once, paste the refresh token here
# so the tool can re-authenticate automatically on subsequent runs.
YOUTUBE_REFRESH_TOKEN=your_refresh_token_here
